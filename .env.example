# ============================================
# PRINT SERVER v2.0 — Configuración
# ============================================
# Copia este archivo como .env y rellena los valores

# URL de la API en la nube
API_URL=https://api-foodly.onrender.com

# ID del tenant (restaurante) — OBLIGATORIO
TENANT_ID=

# Puerto del servidor local
PORT=9001

# ============================================
# IMPRESORAS (none = simulado, network = real)
# ============================================
PRINTER_COCINA_TYPE=none
PRINTER_COCINA_HOST=192.168.1.100
PRINTER_COCINA_PORT=9100

PRINTER_BAR_TYPE=none
PRINTER_BAR_HOST=192.168.1.101
PRINTER_BAR_PORT=9100

PRINTER_CAJA_TYPE=none
PRINTER_CAJA_HOST=192.168.1.102
PRINTER_CAJA_PORT=9100
